{% extends 'base.html.twig' %}

{% block title %}Hello DefaultController!{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/e-portfolio.css') }}">
{% endblock %}

{% block body %}

    <div>

        <div class="bg-img-top">
            <div class="w-100 h-100 d-flex justify-content-center align-items-center">
                <h1 class="bg-color-txt">E-Portfolio</h1>
            </div>
        </div>
        <nav id="scrollspy" class="scrollspy position-fixed d-lg-flex d-none top-50">
            <ul class="nav-menu m-0 p-0">
                <li>
                    <a data-scroll="diplomaAndTrainig" href="#diplomaAndTrainig" class="dot">
                        <span> {{ 'e-portfolio.diplome.title' | trans }}</span>
                    </a>
                </li>
                <li>
                    <a data-scroll="experiencies" href="#experiencies" class="dot">
                        <span>{{ 'e-portfolio.experience.title' | trans }}</span>
                    </a>
                </li>
                <li>
                    <a data-scroll="events" href="#events" class="dot">
                        <span>{{ 'e-portfolio.event.title' | trans }}</span>
                    </a>
                </li>
