                    <a data-scroll="hobies" href="#hobies" class="dot">
                        <span>{{ 'e-portfolio.hobies.title' | trans }}</span>
                    </a>
                </li>
                <li>
                    <a data-scroll="contact" href="#contact" class="dot">
                        <span>Contact</span>
                    </a>
                </li>
            </ul>
        </nav>
        <div class="my-3">
            <section class="py-5">
                <div class="container">
                    <div class="row">
                        <div class="col-3 p-3">
                            <img src="{{ asset('img/pictures/profil.jpeg') }}" width="100%" class="rounded-circle"
                                 alt="">
                        </div>
                        <div class="col-9 d-flex flex-column justify-content-center">
                            <h2 class="bg-color-txt">{{ 'e-portfolio.h1.title' | trans }}</h2>
                            <p class="text-justify">
                                {{ 'e-portfolio.h1.desc' | trans({'name': '<u>Maxime POUJOL</u>', 'age': age}) | raw }}
                            </p>
                            <div class="text-center">
                                <a class="btn btn-1 mx-3 rounded-pill">{{ 'e-portfolio.h1.btn.cv' | trans }}</a>
                                <a class="btn btn-2 mx-3 rounded-pill">{{ 'e-portfolio.h1.btn.contact' | trans }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section id="diplomaAndTrainig" class="py-5 bg-color">
                <div class="container color-white">
                    <div class="text-center py-4">
                        <h2>{{ 'e-portfolio.diplome.title' | trans }}</h2>
                    </div>
                    <div class="py-2">
                        <h3 class="h4 fw-normal">
                            {{ 'e-portfolio.diplome.college.title' | trans }}
                        </h3>
                        <div class="container">
                            <div class="mx-3">
                                <div class="p-1">
                                    <svg width="20" height="20" fill="red" class="me-1">
                                        <use xlink:href="#geo"/>
                                    </svg>
                                    {{ 'e-portfolio.diplome.college.lieu' | trans }}
                                </div>
                                <div class="p-1">
                                    <svg width="20" height="20" fill="red" class="me-1">
                                        <use xlink:href="#planning"/>
                                    </svg>
                                    {% set dateDebut = ("2012-09-3" | format_date) %}
                                    {% set dateFin = ("2016-07-4" | format_date) %}
                                    {{ 'e-portfolio.diplome.college.planning' | trans({'dateDebut' : dateDebut, 'dateFin' : dateFin}) }}
                                </div>
                            </div>
                        </div>
                    </div>
